// -------------------------------------------------------------
// NEW SAAS ARCHITECTURE TABLES (QUEUE, WEBHOOKS, LEDGER LOGS)
// -------------------------------------------------------------

model WebhookDeliveryLog {
  id              String   @id @default(cuid())
  merchantId      String
  endpointUrl     String
  event           String
  requestHeaders  Json?
  requestPayload  Json
  responseStatus  Int?
  responseHeaders Json?
  responseBody    Json?
  latencyMs       Int?
  isSuccess       Boolean  @default(false)
  attemptCount    Int      @default(1)
  errorReason     String?  @db.Text
  createdAt       DateTime @default(now())

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId, isSuccess, createdAt])
}

model DeadLetterQueue {
  id            String   @id @default(cuid())
  queueName     String
  jobId         String   @unique
  jobData       Json
  failedReason  String   @db.Text
  attemptCount  Int
  lastAttemptAt DateTime
  isResolved    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([queueName, isResolved, createdAt])
}

model MerchantLedgerMovement {
  id              String   @id @default(cuid())
  merchantId      String
  orderId         String?
  type            String // ESCROW_IN, ESCROW_OUT, AVAILABLE_IN, AVAILABLE_OUT, PAYOUT, COMMISSION, FEE
  amount          Float
  description     String
  escrowBefore    Float
  escrowAfter     Float
  availableBefore Float
  availableAfter  Float
  createdAt       DateTime @default(now())

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId, type, createdAt])
}

model FlashSaleEvent {
  id            String    @id @default(cuid())
  merchantId    String
  name          String
  description   String?
  startTime     DateTime
  endTime       DateTime
  isActive      Boolean   @default(false)
  discountType  String    @default("PERCENTAGE") // PERCENTAGE | FLAT
  discountValue Float     @default(0)
  bannerImageUrl String?
  maxUsage      Int?
  usedCount     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  items         FlashSaleItem[]
  merchant      Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId, isActive, startTime, endTime])
}

model FlashSaleItem {
  id              String @id @default(cuid())
  flashSaleId     String
  productSkuId    String
  originalPrice   Float
  salePrice       Float
  stockLimit      Int?
  soldCount       Int    @default(0)
  flashSale       FlashSaleEvent @relation(fields: [flashSaleId], references: [id], onDelete: Cascade)
  productSku      ProductSku     @relation(fields: [productSkuId], references: [id])
}
