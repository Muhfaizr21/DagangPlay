md-6 col-6\">\n                        <div class=\"main-footer__title pt-2\">Company</div>\n                        <ul class=\"list-unstyled\">\n                            <li>\n                                <a href=\"https://tripay.co.id/page/about-us\"\n                                    >Tentang Kami</a\n                                >\n                            </li>\n                            <li>\n                                <a\n                                    href=\"https://tripay.co.id/page/privacy-policy\"\n                                    >Kebijakan Privasi</a\n                                >\n                            </li>\n                            <li>\n                                <a\n                                    href=\"https://tripay.co.id/page/terms-and-conditions\"\n                                    >Syarat & Ketentuan</a\n                                >\n                            </li>\n                            <li>\n                                <a\n                                    href=\"https://tripay.co.id/page/referral-policy\"\n                                    >Kebijakan Program Referral</a\n                                >\n                            </li>\n                        </ul>\n                    </div>\n                    <div class=\"col-lg-3 col-md-6 col-6\">\n                        <div class=\"main-footer__title pt-2\">Services</div>\n                        <ul class=\"list-unstyled\">\n                            <li>\n                                <a\n                                    target=\"_blank\"\n                                    href=\"https://tutorial.tripay.co.id\"\n                                    >Pusat Bantuan</a\n                                >\n                            </li>\n                            <li>\n                                <a href=\"#\">Channel Pembayaran</a>\n                            </li>\n                            <li>\n                                <a href=\"#\">Keamanan</a>\n                            </li>\n                        </ul>\n                    </div>\n                    \n                    <div class=\"col-lg-3 col-md-6 col-12\">\n                   \n                        <img src=\"https://tripay.co.id/assets/images/security_logo.png\" class=\"security-logo\" alt=\"security-logo\">\n\n                        <p class=\"footerb\">TriPay merupakan platform yang dikembangkan oleh PT TRIJAYA DIGITAL GRUP yang telah terdaftar sebagai Penyelenggara Sistem Elektronik (PSE) di Kominfo RI. TriPay tidak bekerja secara mandiri dalam menyediakan produk jasa keuangan yang diatur oleh peraturan perundang-undangan. TriPay bekerjasama dengan perusahaan payment gateway terlisensi dan teregulasi serta bekerjasama juga dengan mitra bank dalam negeri yang diawasi oleh Otoritas Jasa Keuangan (OJK) Republik Indonesia. Proses pembayaran dan penyimpanan dana dilakukan oleh mitra bank terkait.</p>\n                    </div>\n                </div>\n                <div class=\"second-footer\">\n                    © 2025 TriPay by\n                    <a href=\"https://trihariyanto.com/\">PT Trijaya Digital Grup </a>\n                </div>\n            </div>\n        </footer>\n        <script\n            data-cfasync=\"false\"\n            src=\"/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js\"\n        ></script>\n        <script src=\"https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js\"></script>\n        <script\n            src=\"https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.12.9/umd/popper.min.js\"\n            integrity=\"sha384-ApNbgh9B+Y1QKtv3Rn7W3mgPxhU9K/ScQsAP7hUibX39j7fakFPskvXusvfa0b4Q\"\n            crossorigin=\"anonymous\"\n        ></script>\n        <script\n            src=\"https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/js/bootstrap.min.js\"\n            integrity=\"sha384-JZR6Spejh4U02d8jOt6vLEHfe/JQGiRRSQQxSfFWpi1MquVdAyjUar5+76PVCmYl\"\n            crossorigin=\"anonymous\"\n        ></script>\n        <script src=\"https://unpkg.com/aos@2.3.1/dist/aos.js\"></script>\n        <script src=\"//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js\"></script>\n        <script src=\"https://tripay.co.id/new-template/js/custom.js?rev=1689157307\"></script>\n        <script>\n            $(function () {\n                $('[data-toggle=\"tooltip\"]').tooltip();\n                AOS.init({\n                    once: false,\n                });\n            });\n            $.ajaxSetup({\n                headers: {\n                    \"X-CSRF-TOKEN\": $('meta[name=\"csrf-token\"]').attr(\n                        \"content\"\n                    ),\n                },\n            });\n            toastr.options.closeMethod = \"fadeOut\";\n            toastr.options.closeDuration = 300;\n            toastr.options.closeEasing = \"swing\";\n        </script>\n        <script src=\"https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/owl.carousel.js\"></script>\n        <script src=\"https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.13.4/jquery.mask.min.js\"></script>\n        <script src=\"https://unpkg.com/typewriter-effect@latest/dist/core.js\"></script>\n        <script>\n            /* Pop Up Whatsapp */\n            hideChat(0);\n            $(\"#prime\").click(function () {\n                toggleFab();\n            });\n            //Toggle chat and links\n            function toggleFab() {\n                $(\".prime\").toggleClass(\"zmdi-whatsapp\");\n                $(\".prime\").toggleClass(\"zmdi-close\");\n                $(\".prime\").toggleClass(\"is-active\");\n                $(\".prime\").toggleClass(\"is-visible\");\n                $(\"#prime\").toggleClass(\"is-float\");\n                $(\".chat\").toggleClass(\"is-visible\");\n                $(\".fab\").toggleClass(\"is-visible\");\n                $(\"#chatSend\").val(\n                    \"Halo! Saya mau menanyakan layanan Payment Tripay. Saya lihat dari Website\"\n                );\n                if ($(\".chat\").is(\":visible\")) {\n                    $(\".chat\").hide();\n                } else {\n                    $(\".chat\").show();\n                }\n            }\n\n            function hideChat(hide) {\n                switch (hide) {\n                    case 0:\n                        $(\"#chat_converse\").css(\"display\", \"none\");\n                        $(\"#chat_body\").css(\"display\", \"none\");\n                        $(\"#chat_form\").css(\"display\", \"none\");\n                        $(\".chat_login\").css(\"display\", \"block\");\n                        $(\".chat_fullscreen_loader\").css(\"display\", \"none\");\n                        $(\"#chat_fullscreen\").css(\"display\", \"none\");\n                        break;\n                }\n            }\n            popupWhatsApp = () => {\n                let sendBtn = document.getElementById(\"fab_send\");\n                sendBtn.addEventListener(\"click\", () => {\n                    let msg = document.getElementById(\"chatSend\").value;\n                    let relmsg = msg.replace(/ /g, \"%20\");\n                    window.open(\n                        \"https://wa.me/6285730000727?text=\" + relmsg,\n                        \"_blank\"\n                    );\n                });\n            };\n            popupWhatsApp();\n            // Cache selectors\n            var lastId,\n                topMenu = $(\"#top-menu\"),\n                topMenuHeight = topMenu.outerHeight() + 80,\n                // All list items\n                menuItems = topMenu.find(\"a.scroll-to\"),\n                // Anchors corresponding to menu items\n                scrollItems = menuItems.map(function () {\n                    var id = $(this).attr(\"href\");\n                    var item = $(id);\n                    if (item.length) {\n                        return item;\n                    }\n                });\n            // Bind click handler to menu items\n            // so we can get a fancy scroll animation\n            menuItems.click(function (e) {\n                var href = $(this).attr(\"href\"),\n                    offsetTop =\n                        href === \"#\"\n                            ? 0\n                            : $(href).offset().top - topMenuHeight + 1;\n                $(\"html, body\").stop().animate(\n                    {\n                        scrollTop: offsetTop,\n                    },\n                    500\n                );\n                e.preventDefault();\n            });\n            // Bind to scroll\n            $(window).scroll(function () {\n                // Get container scroll position\n                var fromTop = $(this).scrollTop() + topMenuHeight;\n                // Get id of current scroll item\n                var cur = scrollItems.map(function () {\n                    if ($(this).offset().top < fromTop) return this;\n                });\n                // Get the id of the current element\n                cur = cur[cur.length - 1];\n                var id = cur && cur.length ? cur[0].id : \"\";\n                if (lastId !== id) {\n                    lastId = id;\n                    // Set/remove active class\n                    menuItems\n                        .parent()\n                        .removeClass(\"active\")\n                        .end()\n                        .filter(\"[href='#\" + id + \"']\")\n                        .parent()\n                        .addClass(\"active\");\n                }\n            });\n            /** Owl Carousel **/\n            $(\".owl-carousel\").owlCarousel({\n                navText: [\" \", \" \"],\n                loop: true,\n                margin: 10,\n                nav: true,\n                autoplay: true,\n                autoplayTimeout: 3000,\n                autoplayHoverPause: true,\n                responsive: {\n                    0: {\n                        items: 1,\n                    },\n                    600: {\n                        items: 3,\n                    },\n                    1000: {\n                        items: 5,\n                    },\n                },\n            });\n            //Text Animation\n            var text = \"Terima Pembayaran dengan pilihan metode terlengkap\";\n            var index = 0;\n            var typeWriter = setInterval(function () {\n                document.querySelector(\".data\").textContent += text[index];\n                index += 1;\n                if (index > text.length - 1) {\n                    clearInterval(typeWriter);\n                }\n            }, 50);\n            \n            function showAnnouncementModal() {\n                document.getElementById(\"announcementModal\").style.display = \"block\";\n            }\n\n            function closeAnnouncementModal() {\n                document.getElementById(\"announcementModal\").style.display = \"none\";\n            }\n            \n            window.onload = function() {\n                showAnnouncementModal(); \n            };\n        </script>\n    </body>\n</html>\n"],"timestamp":"2026-03-14T19:11:02.918Z"}
