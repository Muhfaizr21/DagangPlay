 <p class=\"card-text\">\n                                    Dapatkan biaya yang kompetitif dan\n                                    transparan untuk setiap transaksi sukses.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div\n                        class=\"col-lg-3 col-md-6 col-12\"\n                        data-aos=\"fade-up\"\n                        data-aos-delay=\"1000\"\n                    >\n                        <div class=\"card\">\n                            <div class=\"card-body\">\n                                <img\n                                    src=\"https://tripay.co.id/new-template/icon/api.svg\"\n                                    alt=\"api-icon\"\n                                />\n                                <h5 class=\"card-title\">\n                                    API & <span>Integrasi</span>\n                                </h5>\n                                <p class=\"card-text\">\n                                    Single API untuk semua channel dan tersedia\n                                    dokumentasi lengkap, simulator serta plugin\n                                    dari CMS terkemuka.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </section>\n        <section class=\"explain\">\n            <div class=\"container\">\n                <div class=\"row\">\n                    <div class=\"col-lg-6 hide-dekstop\" data-aos=\"fade-right\">\n                        <img\n                            src=\"https://tripay.co.id/new-template/icon/shield.svg\"\n                            alt=\"icon\"\n                            class=\"bubble-1\"\n                        />\n                        <img\n                            src=\"https://tripay.co.id/new-template/icon/price-circle.svg\"\n                            alt=\"icon\"\n                            class=\"bubble-2\"\n                        />\n                        <img\n                            src=\"https://tripay.co.id/new-template/icon/balance-circle.svg\"\n                            alt=\"icon\"\n                            class=\"bubble-3\"\n                        />\n                        <img\n                            src=\"https://tripay.co.id/new-template/icon/notification-circle.svg\"\n                            alt=\"icon\"\n                            class=\"bubble-4\"\n                        />\n                        <img\n                            src=\"https://tripay.co.id/new-template/images/landing-page-3.svg\"\n                            alt=\"illustration\"\n                            class=\"bg__illustration\"\n                        />\n                    </div>\n                    <div class=\"col-lg-5 offset-lg-1\" data-aos=\"fade-left\">\n                        <h1 class=\"title\">\n                            Solusi B2B sistem pembayaran online terlengkap\n                        </h1>\n                        <ol class=\"list-group\">\n                            <li class=\"list-group-item\">\n                                Pendaftaran mudah & cepat\n                            </li>\n                            <li class=\"list-group-item\">\n                                GRATIS biaya bulanan\n                            </li>\n                            <li class=\"list-group-item\">\n                                Biaya kompetitif & transparan\n                            </li>\n                            <li class=\"list-group-item\">\n                                Banyak pilihan metode pembayaran\n                            </li>\n                            <li class=\"list-group-item\">\n                                Notifikasi pembayaran instan\n                            </li>\n          