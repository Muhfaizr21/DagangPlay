at_field {\n                    width: 65%;\n                }\n\n                .fabs {\n                    right: 30px;\n                }\n            }\n\n            /* TABLETS PORTRAIT */\n            @media only screen and (min-width: 768px) {\n                .chat {\n                    width: 300px;\n                }\n\n                .chat_field {\n                    width: 65%;\n                }\n            }\n\n            /* TABLET LANDSCAPE / DESKTOP */\n            @media only screen and (min-width: 1024px) {\n                .chat {\n                    width: 300px;\n                }\n\n                .chat_field {\n                    width: 65%;\n                }\n            }\n\n            /*Color Options*/\n            .blue .fab {\n                background: #42a5f5;\n                color: #fff;\n            }\n\n            .blue .chat {\n                background: #42a5f5;\n                color: #999;\n            }\n\n            /* Ripple */\n            .ink {\n                display: block;\n                position: absolute;\n                background: rgba(38, 50, 56, 0.4);\n                border-radius: 100%;\n                -moz-transform: scale(0);\n                -ms-transform: scale(0);\n                webkit-transform: scale(0);\n                -webkit-transform: scale(0);\n                transform: scale(0);\n            }\n\n            /*animation effect*/\n            .ink.animate {\n                -webkit-animation: ripple 0.5s ease-in-out;\n                animation: ripple 0.5s ease-in-out;\n            }\n\n            @-webkit-keyframes ripple {\n                /*scale the element to 250% to safely cover the entire link and fade it out*/\n                100% {\n                    opacity: 0;\n                    -moz-transform: scale(5);\n                    -ms-transform: scale(5);\n                    webkit-transform: scale(5);\n                    -webkit-transform: scale(5);\n                    transform: scale(5);\n                }\n            }\n\n            @keyframes ripple {\n                /*scale the element to 250% to safely cover the entire link and fade it out*/\n                100% {\n                    opacity: 0;\n                    -moz-transform: scale(5);\n                    -ms-transform: scale(5);\n                    webkit-transform: scale(5);\n                    -webkit-transform: scale(5);\n                    transform: scale(5);\n                }\n            }\n\n            .fab_field > textarea::-webkit-input-placeholder {\n                /* Chrome */\n                color: #bbb;\n            }\n\n            .fab_field > textarea:-ms-input-placeholder {\n                /* IE 10+ */\n                color: #bbb;\n            }\n\n            .fab_field > textarea::-moz-placeholder {\n                /* Firefox 19+ */\n                color: #bbb;\n            }\n\n            .fab_field > textarea:-moz-placeholder {\n                /* Firefox 4 - 18 */\n                color: #bbb;\n            }\n\n            /* Penutup Chat Whatsapp */\n            /** Back to top Button **/\n            #button {\n                display: inline-block;\n                background-color: #0cb4ff;\n                width: 50px;\n                height: 50px;\n                text-align: center;\n                border-radius: 50%;\n                position: fixed;\n                bottom: 110px;\n                right: 34px;\n                -webkit-transition: all 0.4s ease;\n                transition: all 0.4s ease;\n                opacity: 0;\n                visibility: hidden;\n                z-index: 1000;\n            }\n\n            #button::after {\n                content: \"\\f077\";\n                font-family: \"Font Awesome 5 Free\";\n                font-weight: 800;\n                font-style: normal;\n                font-size: 1em;\n                line-height: 50px;\n                color: #fff;\n            }\n\n            #button:hover {\n                cursor: pointer;\n                background-color: #038bec;\n            }\n\n            #button:active {\n                background-color: #038be9;\n            }\n\n            #button.show {\n                opacity: 1;\n                visibility: visible;\n            }\n\n            /** Credit **/\n            .credit .title-credit {\n                color: #1e212a;\n                font-size: 18px;\n                font-weight: 600;\n                margin-bottom: 3rem;\n                text-align: center;\n            }\n\n            .credit .credit__carousel .item img {\n                width: 185px;\n                height: auto;\n                max-width: none;\n                margin-left: auto;\n                margin-right: auto;\n                opacity: 0.6;\n                transition: all 0.4s ease;\n            }\n\n            .credit .credit__carousel .item img:hover {\n                opacity: 1;\n            }\n\n            .credit .credit__carousel .owl-dots,\n            .credit .credit__carousel .owl-nav {\n                display: none;\n            }\n\n            @media (max-width: 768px) {\n                /** Credit **/\n                .credit {\n                    margin-bottom: 4rem;\n                }\n\n                .credit .title-credit {\n                    margin-bottom: 2rem;\n                }\n            }\n\n            /* Typing Animation */\n            #homeTitle {\n                font-style: normal;\n                font-weight: 900;\n                font-size: 40px;\n                color: #1e212a;\n                line-height: 56px;\n                margin-top: 2rem;\n                margin-bottom: 1rem;\n            }\n\n            @media (max-width: 768px) {\n                #homeTitle {\n                    color: #1e212a;\n                    font-style: normal;\n                    font-weight: 900;\n                    font-size: 20px;\n                    line-height: 42px;\n                    margin-top: 1rem;\n                }\n            }\n\n            .icon-title {\n                font-size: 14px;\n                color: #a8b3c0;\n                margin-top: -1rem;\n            }\n\n\n\n\n            /* Styling dasar untuk modal pengumuman pendaftaran dituutp  */\n            .modal {\n                display: none;\n                position: fixed;\n                z-index: 1000;\n                left: 0;\n                top: 0;\n                width: 100%;\n                height: 100%;\n                background-color: rgba(0, 0, 0, 0.5);\n            }\n            .modal-dialog {\n                max-width: 800px; \n                width: 90%; \n                margin: 10% auto;\n            }\n            .modal-content {\n                padding: 30px; \n                border-radius: 8px;\n                background-color: #fff;\n            }\n            .modal-header {\n                display: flex;\n                justify-content: space-between;\n                align-items: center;\n            }\n            .modal-title {\n                font-size: 22px; \n            }\n            .close {\n            font-size: 30px; \n            cursor: pointer;\n            }\n            .modal-footer {\n                display: flex;\n                justify-content: flex-end;\n            }\n        </style>\n    </head>\n    <body>\n        <header class=\"\">\n            <nav\n                class=\"navbar navbar-expand-lg navbar-custom header-navigation stricky\"\n            >\n                <div class=\"container\">\n                    <a class=\"navbar-brand\" href=\"https://tripay.co.id\">\n                        <img\n                            src=\"https://tripay.co.id/new-template/images/logo-dark.png\"\n                            alt=\"logo\"\n                            class=\"header__img\"\n                        />\n                    </a>\n      