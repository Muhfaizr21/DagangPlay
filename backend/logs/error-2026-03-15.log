ss=\"mr-4\">\n                                <img\n                                    src=\"https://tripay.co.id/new-template/icon/phone.svg\"\n                                    alt=\"icon\"\n                                />\n                            </div>\n                            <div class=\"flex-column\">\n                                <div class=\"contact__title\">Nomor HP</div>\n                                <div class=\"contact__subtitle\">\n                                    +6285730000727\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                    <div\n                        class=\"col-lg-4 col-12\"\n                        data-aos=\"fade-up\"\n                        data-aos-delay=\"700\"\n                    >\n                        <div class=\"d-flex contact__top\">\n                            <div class=\"mr-4\">\n                                <img\n                                    src=\"https://tripay.co.id/new-template/icon/maps.svg\"\n                                    alt=\"icon\"\n                                />\n                            </div>\n                            <div class=\"flex-column\">\n                                <div class=\"contact__title\">Alamat</div>\n                                <div class=\"contact__subtitle\">\n                                    Ngompak 2, Cepoko, Kec. Ngrambe, Kab. Ngawi\n                                    - Jawa Timur\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </section>\n        <a id=\"button\"></a>\n        <div class=\"fabs\">\n            <div class=\"chat\" style=\"display: none\">\n                <div class=\"chat_header\">\n                    <div class=\"chat_option\">\n                        <div class=\"header_img\">\n                            <img\n                                src=\"https://tripay.co.id/new-template/images/cs.png\"\n                                alt=\"cs\"\n                            />\n                        </div>\n                        <span id=\"chat_head\">Payment Tripay</span>\n                        <div class=\"online\">(Online)</div>\n                    </div>\n                </div>\n                <div class=\"chat_body chat_login\">\n                    <p>Hallo, Apa yang bisa kami bantu?</p>\n                </div>\n                <div class=\"fab_field\">\n                    <a id=\"fab_send\" class=\"fab\">\n                        <i class=\"zmdi zmdi-mail-send\"></i>\n                    </a>\n                    <textarea\n                        id=\"chatSend\"\n                        name=\"chat_message\"\n                        placeholder=\"Send a message\"\n                        class=\"chat_field chat_message\"\n                    ></textarea>\n                </div>\n            </div>\n            <a id=\"prime\" class=\"fab\">\n                <i class=\"prime zmdi zmdi-whatsapp text-white\"></i>\n            </a>\n        </div>\n\n\n\n        <div id=\"announcementModal\" class=\"modal\" tabindex=\"-1\" role=\"dialog\">\n            <div class=\"modal-dialog\" role=\"document\">\n                <div class=\"modal-content\">\n                    <div class=\"modal-header\">\n                        <h5 class=\"modal-title\">📢 Pengumuman untuk Partner TriPay</h5>\n                        <button type=\"button\" class=\"close\" onclick=\"closeAnnouncementModal()\">\n                            &times;\n                        </button>\n                    </div>\n                    <div class=\"modal-body\">\n                        <p>Halo Partner TriPay,</p>\n                        <p>\n                            Kami ingin menginformasikan bahwa saat ini pendaftaran untuk\n                      