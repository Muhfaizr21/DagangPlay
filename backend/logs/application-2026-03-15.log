ss=\"mr-4\">\n                                <img\n                                    src=\"https://tripay.co.id/new-template/icon/phone.svg\"\n                                    alt=\"icon\"\n                                />\n                            </div>\n                            <div class=\"flex-column\">\n                                <div class=\"contact__title\">Nomor HP</div>\n                                <div class=\"contact__subtitle\">\n                                    +6285730000727\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                    <div\n                        class=\"col-lg-4 col-12\"\n                        data-aos=\"fade-up\"\n                        data-aos-delay=\"700\"\n                    >\n                        <div class=\"d-flex contact__top\">\n                            <div class=\"mr-4\">\n                                <img\n                                    src=\"https://tripay.co.id/new-template/icon/maps.svg\"\n                                    alt=\"icon\"\n                                />\n                            </div>\n                            <div class=\"flex-column\">\n                                <div class=\"contact__title\">Alamat</div>\n                                <div class=\"contact__subtitle\">\n                                    Ngompak 2, Cepoko, Kec. Ngrambe, Kab. Ngawi\n                                    - Jawa Timur\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </section>\n        <a id=\"button\"></a>\n        <div class=\"fabs\">\n            <div class=\"chat\" style=\"display: none\">\n                <div class=\"chat_header\">\n                    <div class=\"chat_option\">\n                        <div class=\"header_img\">\n                            <img\n                                src=\"https://tripay.co.id/new-template/images/cs.png\"\n                                alt=\"cs\"\n                            />\n                        </div>\n                        <span id=\"chat_head\">Payment Tripay</span>\n                        <div class=\"online\">(Online)</div>\n                    </div>\n                </div>\n                <div class=\"chat_body chat_login\">\n                    <p>Hallo, Apa yang bisa kami bantu?</p>\n                </div>\n                <div class=\"fab_field\">\n                    <a id=\"fab_send\" class=\"fab\">\n                        <i class=\"zmdi zmdi-mail-send\"></i>\n                    </a>\n                    <textarea\n                        id=\"chatSend\"\n                        name=\"chat_message\"\n                        placeholder=\"Send a message\"\n                        class=\"chat_field chat_message\"\n                    ></textarea>\n                </div>\n            </div>\n            <a id=\"prime\" class=\"fab\">\n                <i class=\"prime zmdi zmdi-whatsapp text-white\"></i>\n            </a>\n        </div>\n\n\n\n        <div id=\"announcementModal\" class=\"modal\" tabindex=\"-1\" role=\"dialog\">\n            <div class=\"modal-dialog\" role=\"document\">\n                <div class=\"modal-content\">\n                    <div class=\"modal-header\">\n                        <h5 class=\"modal-title\">📢 Pengumuman untuk Partner TriPay</h5>\n                        <button type=\"button\" class=\"close\" onclick=\"closeAnnouncementModal()\">\n                            &times;\n                        </button>\n                    </div>\n                    <div class=\"modal-body\">\n                        <p>Halo Partner TriPay,</p>\n                        <p>\n                            Kami ingin menginformasikan bahwa saat ini pendaftaran untuk\n                            pengguna baru di TriPay ditutup sementara. Hal ini dilakukan\n                            karena kami sedang melakukan peningkatan sistem untuk\n                            meningkatkan keamanan, stabilitas, dan kenyamanan pengguna 😊.\n                        </p>\n                        <p>\n                            Jika ada pertanyaan lebih lanjut atau kebutuhan mendesak, jangan\n                            ragu untuk menghubungi tim support kami 📞.\n                        </p>\n                        <p>Terima kasih atas dukungan dan kepercayaan Anda pada TriPay 🌟.</p>\n                        <p>Salam hangat,<br />Tim TriPay</p>\n                    </div>\n                    <div class=\"modal-footer\">\n                        <button type=\"button\" class=\"btn btn-secondary\" onclick=\"closeAnnouncementModal()\">\n                            Tutup\n                        </button>\n                    </div>\n                </div>\n            </div>\n        </div>\n        \n\n\n        <footer class=\"main-footer\">\n            <div class=\"container\">\n                <div class=\"row\">\n                    <div class=\"col-lg-3 col-md-6 col-12\">\n                        <img\n                            src=\"https://tripay.co.id/new-template/images/logo-white.png\"\n                            alt=\"\"\n                        />\n                        <div class=\"main-footer__subtitle mt-5 mb-3\">\n                            <a href=\"https://trihariyanto.com/\"\n                                >PT Trijaya Digital Group\n                            </a>\n                        </div>\n                        <div class=\"main-footer__subtitle\">\n                            Dsn. Ngompak 2 Ds. Cepoko <br />\n                            Kec. Ngrambe 63263, Kab. Ngawi <br />\n                            Jawa Timur, Indonesia\n                        </div>\n                    </div>\n                    <div class=\"col-lg-3 col-md-6 col-6\">\n                        <div class=\"main-footer__title pt-2\">Company</div>\n                        <ul class=\"list-unstyled\">\n                            <li>\n                                <a href=\"https://tripay.co.id/page/about-us\"\n                                    >Tentang Kami</a\n                                >\n                            </li>\n                            <li>\n                                <a\n                                    href=\"https://tripay.co.id/page/privacy-policy\"\n                                    >Kebijakan Privasi</a\n                                >\n                            </li>\n                            <li>\n                                <a\n                                    href=\"https://tripay.co.id/page/terms-and-conditions\"\n                                    >Syarat & Ketentuan</a\n                                >\n                            </li>\n                            <li>\n                                <a\n                                    href=\"https://tripay.co.id/page/referral-policy\"\n                                    >Kebijakan Program Referral</a\n                                >\n                            </li>\n                        </ul>\n                    </div>\n                    <div class=\"col-lg-3 col-md-6 col-6\">\n                        <div class=\"main-footer__title pt-2\">Services</div>\n                        <ul class=\"list-unstyled\">\n                            <li>\n                                <a\n                                    target=\"_blank\"\n                                    href=\"https://tutorial.tripay.co.id\"\n                                    >Pusat Bantuan</a\n                                >\n                            </li>\n                            <li>\n                                <a href=\"#\">Channel Pembayaran</a>\n                            </li>\n                            <li>\n                                <a href=\"#\">Keamanan</a>\n                            </li>\n                        </ul>\n                    </div>\n                    \n                    <div class=\"col-lg-3 col-md-6 col-12\">\n                   \n                        <img src=\"https://tripay.co.id/assets/images/security_logo.png\" class=\"security-logo\" alt=\"security-logo\">\n\n                        <p class=\"footerb\">TriPay merupakan platform yang dikembangkan oleh PT TRIJAYA DIGITAL GRUP yang telah terdaftar sebagai Penyelenggara Sistem Elektronik (PSE) di Kominfo RI. TriPay tidak bekerja secara mandiri dalam menyediakan produk jasa keuangan yang diatur oleh peraturan perundang-undangan. TriPay bekerjasama dengan perusahaan payment gateway terlisensi dan teregulasi serta bekerjasama juga dengan mitra bank dalam negeri yang diawasi oleh Otoritas Jasa Keuangan (OJK) Republik Indonesia. Proses pembayaran dan penyimpanan dana dilakukan oleh mitra bank terkait.</p>\n                    </div>\n                </div>\n                <div class=\"second-footer\">\n                    © 2025 TriPay by\n                    <a href=\"https://trihariyanto.com/\">PT Trijaya Digital Grup </a>\n                </div>\n            </div>\n        </footer>\n        <script\n            data-cfasync=\"false\"\n            src=\"/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js\"\n        ></script>\n        <script src=\"https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js\"></script>\n        <script\n            src=\"https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.12.9/umd/popper.min.js\"\n            integrity=\"sha384-ApNbgh9B+Y1QKtv3Rn7W3mgPxhU9K/ScQsAP7hUibX39j7fakFPskvXusvfa0b4Q\"\n            crossorigin=\"anonymous\"\n        ></script>\n        <script\n            src=\"https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/js/bootstrap.min.js\"\n            integrity=\"sha384-JZR6Spejh4U02d8jOt6vLEHfe/JQGiRRSQQxSfFWpi1MquVdAyjUar5+76PVCmYl\"\n            crossorigin=\"anonymous\"\n        ></script>\n        <script src=\"https://unpkg.com/aos@2.3.1/dist/aos.js\"></script>\n        <script src=\"//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js\"></script>\n        <script src=\"https://tripay.co.id/new-template/js/custom.js?rev=1689157307\"></script>\n        <script>\n            $(function () {\n                $('[data-toggle=\"tooltip\"]').tooltip();\n                AOS.init({\n                    once: false,\n                });\n            });\n            $.ajaxSetup({\n                headers: {\n                    \"X-CSRF-TOKEN\": $('meta[name=\"csrf-token\"]').attr(\n                        \"content\"\n                    ),\n                },\n            });\n            toastr.options.closeMethod = \"fadeOut\";\n            toastr.options.closeDuration = 300;\n            toastr.options.closeEasing = \"swing\";\n        </script>\n        <script src=\"https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/owl.carousel.js\"></script>\n        <script src=\"https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.13.4/jquery.mask.min.js\"></script>\n        <script src=\"https://unpkg.com/typewriter-effect@latest/dist/core.js\"></script>\n        <script>\n            /* Pop Up Whatsapp */\n            hideChat(0);\n            $(\"#prime\").click(function () {\n                toggleFab();\n            });\n            //Toggle chat and links\n            function toggleFab() {\n                $(\".prime\").toggleClass(\"zmdi-whatsapp\");\n                $(\".prime\").toggleClass(\"zmdi-close\");\n                $(\".prime\").toggleClass(\"is-active\");\n                $(\".prime\").toggleClass(\"is-visible\");\n                $(\"#prime\").toggleClass(\"is-float\");\n                $(\".chat\").toggleClass(\"is-visible\");\n                $(\".fab\").toggleClass(\"is-visible\");\n                $(\"#chatSend\").val(\n                    \"Halo! Saya mau menanyakan layanan Payment Tripay. Saya lihat dari Website\"\n                );\n                if ($(\".chat\").is(\":visible\")) {\n                    $(\".chat\").hide();\n                } else {\n                    $(\".chat\").show();\n                }\n            }\n\n            function hideChat(hide) {\n                switch (hide) {\n                    case 0:\n                        $(\"#chat_converse\").css(\"display\", \"none\");\n                        $(\"#chat_body\").css(\"display\", \"none\");\n                        $(\"#chat_form\").css(\"display\", \"none\");\n                        $(\".chat_login\").css(\"display\", \"block\");\n                        $(\".chat_fullscreen_loader\").css(\"display\", \"none\");\n                        $(\"#chat_fullscreen\").css(\"display\", \"none\");\n                        break;\n                }\n            }\n            popupWhatsApp = () => {\n                let sendBtn = document.getElementById(\"fab_send\");\n                sendBtn.addEventListener(\"click\", () => {\n                    let msg = document.getElementById(\"chatSend\").value;\n                    let relmsg = msg.replace(/ /g, \"%20\");\n                    window.open(\n                        \"https://wa.me/6285730000727?text=\" + relmsg,\n                        \"_blank\"\n                    );\n                });\n            };\n            popupWhatsApp();\n            // Cache selectors\n            var lastId,\n                topMenu = $(\"#top-menu\"),\n                topMenuHeight = topMenu.outerHeight() + 80,\n                // All list items\n                menuItems = topMenu.find(\"a.scroll-to\"),\n                // Anchors corresponding to menu items\n                scrollItems = menuItems.map(function () {\n                    var id = $(this).attr(\"href\");\n                    var item = $(id);\n                    if (item.length) {\n                        return item;\n                    }\n                });\n            // Bind click handler to menu items\n            // so we can get a fancy scroll animation\n            menuItems.click(function (e) {\n                var href = $(this).attr(\"href\"),\n                    offsetTop =\n                        href === \"#\"\n                            ? 0\n                            : $(href).offset().top - topMenuHeight + 1;\n                $(\"html, body\").stop().animate(\n                    {\n                        scrollTop: offsetTop,\n                    },\n                    500\n                );\n                e.preventDefault();\n            });\n            // Bind to scroll\n            $(window).scroll(function () {\n                // Get container scroll position\n                var fromTop = $(this).scrollTop() + topMenuHeight;\n                // Get id of current scroll item\n                var cur = scrollItems.map(function () {\n                    if ($(this).offset().top < fromTop) return this;\n                });\n                // Get the id of the current element\n                cur = cur[cur.length - 1];\n                var id = cur && cur.length ? cur[0].id : \"\";\n                if (lastId !== id) {\n                    lastId = id;\n                    // Set/remove active class\n                    menuItems\n                        .parent()\n                        .removeClass(\"active\")\n                        .end()\n                        .filter(\"[href='#\" + id + \"']\")\n                        .parent()\n                        .addClass(\"active\");\n                }\n            });\n            /** Owl Carousel **/\n            $(\".owl-carousel\").owlCarousel({\n                navText: [\" \", \" \"],\n                loop: true,\n                margin: 10,\n                nav: true,\n                autoplay: true,\n                autoplayTimeout: 3000,\n                autoplayHoverPause: true,\n                responsive: {\n                    0: {\n                        items: 1,\n                    },\n                    600: {\n                        items: 3,\n                    },\n                    1000: {\n                        items: 5,\n                    },\n                },\n            });\n            //Text Animation\n            var text = \"Terima Pembayaran dengan pilihan metode terlengkap\";\n            var index = 0;\n            var typeWriter = setInterval(function () {\n                document.querySelector(\".data\").textContent += text[index];\n                index += 1;\n                if (index > text.length - 1) {\n                    clearInterval(typeWriter);\n                }\n            }, 50);\n            \n            function showAnnouncementModal() {\n                document.getElementById(\"announcementModal\").style.display = \"block\";\n            }\n\n            function closeAnnouncementModal() {\n                document.getElementById(\"announcementModal\").style.display = \"none\";\n            }\n            \n            window.onload = function() {\n                showAnnouncementModal(); \n            };\n        </script>\n    </body>\n</html>\n"],"timestamp":"2026-03-14T19:11:02.917Z"}
