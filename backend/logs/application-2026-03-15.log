          <p class=\"subtitle\">\n                            Tripay menyediakan pilihan channel pembayaran\n                            terlengkap untuk membantu meningkatkan penjualan\n                            Anda dan pengalaman transaksi yang mudah bagi\n                            pelanggan bisnis Anda.\n                        </p>\n                        <a\n                            href=\"#\"\n                            class=\"btn btn-try\"\n                            onclick=\"showAnnouncementModal()\"\n                        >\n                            <div class=\"mb-2\">Tingkatkan Penjualan</div>\n                            <div class=\"d-flex flex-row\">\n                                <div>\n                                    <i\n                                        class=\"fas fa-bolt text-warning fa-2x mr-2\"\n                                    ></i>\n                                </div>\n                                <div>\n                                    <i\n                                        class=\"fas fa-bolt text-warning fa-2x mr-2\"\n                                    ></i>\n                                </div>\n                                <div>\n                                    <i\n                                        class=\"fas fa-bolt text-warning fa-2x mr-2\"\n                                    ></i>\n                                </div>\n                                <div class=\"align-self-center pb-2 mr-2\">\n                                    Sekarang\n                                </div>\n                                <div>\n                                    <i\n                                        class=\"fas fa-bolt text-warning fa-2x mr-2\"\n                                    ></i>\n                                </div>\n                                <div>\n                                    <i\n                                        class=\"fas fa-bolt text-warning fa-2x mr-2\"\n                                    ></i>\n                                </div>\n                                <div>\n                                    <i\n                                        class=\"fas fa-bolt text-warning fa-2x\"\n                                    ></i>\n                                </div>\n                            </div>\n                        </a>\n                    </div>\n                    <div class=\"col-lg-6 hide-dekstop\" data-aos=\"fade-left\">\n                        <img\n                            src=\"https://tripay.co.id/new-template/images/landing-page-1.svg\"\n                            alt=\"illustration\"\n                            class=\"bg__illustration\"\n                        />\n                    </div>\n                </div>\n            </div>\n        </section>\n        <section class=\"features\" id=\"features\">\n            <div class=\"container\">\n                <h1 class=\"title\">Mengapa Memilih Kami?</h1>\n                <div class=\"row custom-card\">\n                    <div\n                        class=\"col-lg-3 col-md-6 col-12\"\n                        data-aos=\"fade-up\"\n                        data-aos-delay=\"100\"\n                    >\n                        <div class=\"card\">\n                            <div class=\"card-body\">\n                                <img\n                                    src=\"https://tripay.co.id/new-template/icon/balance.svg\"\n                                    alt=\"balance-icon\"\n                                />\n                                <h5 class=\"card-title\">\n                                    Multi <span>Channel</span>\n                                </h5>\n                                <p class=\"card-text\">\n                                    Kami menyediakan banyak pilihan channel\n                                    pembayaran yang dapat diintergrasikan dengan\n           