# ─── APP BASE CONFIG ───
FRONTEND_PORT=3000
BACKEND_PORT=3001

# URL ini akan digunakan di frontend untuk memanggil API backend
# Ganti localhost dengan IP Publik atau Domain jika di-deploy ke production
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# URL frontend ini digunakan oleh backend (misal: untuk callback payment)
FRONTEND_URL=http://localhost:3000

# ─── DATABASE CONFIG (PostgreSQL) ───
POSTGRES_USER=postgres
POSTGRES_PASSWORD=admin
POSTGRES_DB=dagangplay
POSTGRES_PORT=5432

# ─── REDIS CONFIG ───
REDIS_PASSWORD=dagangplayredis2026

# ─── BACKEND ENV VARS ───
JWT_SECRET=your_super_secret_jwt_key_here
NODE_ENV=production

# ─── THIRD PARTY API (Digiflazz) ───
DIGIFLAZZ_USERNAME=your_digiflazz_username
DIGIFLAZZ_KEY=your_digiflazz_key
DIGIFLAZZ_URL=https://api.digiflazz.com/v1

# ─── THIRD PARTY API (Tripay) ───
TRIPAY_API_KEY=your_tripay_api_key
TRIPAY_PRIVATE_KEY=your_tripay_private_key
TRIPAY_MERCHANT_CODE=your_tripay_merchant_code
TRIPAY_URL=https://tripay.co.id/api-sandbox
TRIPAY_CALLBACK_URL=http://your-domain.com/tripay/callback

# ─── THIRD PARTY API (Fonnte / WhatsApp) ───
WHATSAPP_API_KEY=your_fonnte_api_key
WHATSAPP_URL=https://api.fonnte.com/send
